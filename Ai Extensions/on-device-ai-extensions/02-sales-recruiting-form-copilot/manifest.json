{
  "manifest_version": 3,
  "name": "Sales & Recruiting Form Copilot",
  "version": "1.0.0",
  "description": "AI-powered form filler for SDRs and recruiters. Maps profile data to any job board or CRM form on-device.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Form Copilot"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
